# =============================================================================
# NeighborHub — Environment Variables
# Both web (Vite) and admin (Angular) consume the same Supabase project.
# Copy this file to `.env` (root) and to per-app `.env` files as needed.
# =============================================================================

# ─── Supabase (shared across both apps) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Mapbox (web only) ───────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ...

# ─── Angular admin (same Supabase project, different prefix) ─────────────────
NG_APP_SUPABASE_URL=https://your-project.supabase.co
NG_APP_SUPABASE_ANON_KEY=eyJ...
NG_APP_MAPBOX_TOKEN=pk.eyJ...
